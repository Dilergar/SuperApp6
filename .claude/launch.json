{
  "version": "0.0.1",
  "autoPort": false,
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "./apps/web", "exec", "next", "dev", "--port", "3000"],
      "port": 3000
    },
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "./apps/api", "exec", "nest", "start", "--watch"],
      "port": 3001
    }
  ]
}
