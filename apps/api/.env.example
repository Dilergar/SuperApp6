# Database
DATABASE_URL="postgresql://superapp:superapp@localhost:5432/superapp6?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=3001
NODE_ENV=development

# Google Calendar (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/calendar/google/callback"

# File Storage (S3-compatible; пусто → FILES_DRIVER=local)
S3_ENDPOINT=""
S3_BUCKET="superapp6"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"

# Голосовой движок (core/voice) — STT. Пусто → расшифровка выключена (движок инертен).
# Self-host: docker compose --profile voice up -d → VOICE_STT_URL=http://localhost:9000
# Облако тем же адаптером: VOICE_STT_URL=https://api.openai.com + VOICE_STT_API_KEY
VOICE_STT_URL=""
VOICE_STT_API_KEY=""
# Модель по умолчанию (whisper-server игнорирует и берёт свою из WHISPER_MODEL)
VOICE_STT_MODEL=""
# Отдельная модель для казахского (слот под дообученную whisper-turbo-ksc2)
VOICE_STT_MODEL_KK=""
# true → mock-драйвер без сети (CI/verify)
VOICE_STT_MOCK=""

# Движок звонков (core/calls) — LiveKit SFU. Пусто → звонки выключены (движок инертен).
# Self-host: docker compose --profile calls up -d → значения ниже
# (секрет = LIVEKIT_DEV_SECRET из docker-compose, ≥32 символов; смени в проде!)
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
# ws-адрес для браузера (пусто → выводится из LIVEKIT_URL заменой http→ws)
LIVEKIT_WS_URL=""
# Запись звонков (кнопка ⏺): хост-каталог, куда egress-контейнер кладёт готовые файлы
# (= bind-mount ./apps/api/storage/egress в docker-compose). Пусто → запись выключена.
# ВАЖНО: задаётся ТОЛЬКО вместе с LIVEKIT_* (валидатор запрещает egress без LiveKit),
# иначе `cp .env.example .env` уронит бут. Включаешь запись → раскомментируй значение ниже.
LIVEKIT_EGRESS_DIR=""
# LIVEKIT_EGRESS_DIR="./storage/egress"
