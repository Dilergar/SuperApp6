generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE: Users & Auth
// ============================================================

model User {
  id               String    @id @default(uuid())
  phone            String    @unique
  password         String // bcrypt hash
  firstName        String    @map("first_name")
  lastName         String?   @map("last_name")
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  avatar           String?
  bio              String?
  city             String?
  email            String?   @unique
  maritalStatus    String?   @map("marital_status")
  socialLinks      Json?     @map("social_links")
  onlineStatusMode String    @default("everyone") @map("online_status_mode")
  isVerified       Boolean   @default(false) @map("is_verified")
  locale           String    @default("ru")
  timezone         String    @default("Asia/Almaty")

  // Contact card visibility — per-field flags controlling what others see on your card
  // Shape: { lastName: bool, dateOfBirth: bool, age: bool, onlineStatus: bool, maritalStatus: bool, extras: {...} }
  // null means use defaults defined in shared/constants. Always-visible (regardless of this): firstName, lastName, phone, role.
  cardVisibility Json? @map("card_visibility")
  // «Видимость в Компаниях» — что видят КОЛЛЕГИ по организации на карточке в ростере
  // «Сотрудники» (та же форма флагов, что cardVisibility). null = те же дефолты.
  // Всегда видны коллегам: имя, фамилия, телефон, должность.
  companyCardVisibility Json? @map("company_card_visibility")

  // Card skins (cosmetic): the equipped default skin instance + premium window
  // (per-group skin overrides require premium). Plain id; ownership validated in service.
  defaultSkinInstanceId String?   @map("default_skin_instance_id")
  premiumUntil          DateTime? @map("premium_until")

  // Soft-deletion in two stages:
  //   deletionScheduledAt — user requested deletion; account is in a recoverable
  //     grace window (logging in restores it). Login via token is blocked.
  //   deletedAt — set by the cron once the grace window elapses; the account is
  //     permanently anonymized (PII scrubbed, phone freed) and login blocked forever.
  // The row is kept so collaborative content (tasks/comments/workspaces) survives.
  deletionScheduledAt DateTime? @map("deletion_scheduled_at")
  deletedAt           DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessions           Session[]
  roles              UserRole[]
  ownedCircles       Circle[]
  createdTasks       Task[]            @relation("TaskCreator")
  taskParticipations TaskParticipant[] @relation("TaskParticipantUser")
  calendarEvents     CalendarEvent[]
  resources          Resource[]
  googleConnection   GoogleConnection?
  workspaceMembers   WorkspaceMember[]
  ownedWorkspaces    Workspace[]
  staffAssignments   StaffAssignment[]

  // Workspace hiring invitations (separate from ContactInvitation — different semantics)
  workspaceInvitationsSent     WorkspaceInvitation[] @relation("WsInvitationInviter")
  workspaceInvitationsReceived WorkspaceInvitation[] @relation("WsInvitationRecipient")

  // Contacts / Circles / Invitations
  contactLinksA       ContactLink[]       @relation("ContactLinkUserA")
  contactLinksB       ContactLink[]       @relation("ContactLinkUserB")
  sentInvitations     ContactInvitation[] @relation("InvitationSender")
  receivedInvitations ContactInvitation[] @relation("InvitationRecipient")

  // Blocks (unidirectional — A blocking B does not imply B blocking A)
  blocksMade     ContactBlock[] @relation("ContactBlockBlocker")
  blocksReceived ContactBlock[] @relation("ContactBlockBlocked")

  // Notifications
  notifications Notification[]

  // Subscription
  subscription Subscription?

  // Messenger
  chatMemberships  ChatMember[]
  authoredMessages Message[]

  // Mentions (Phase 5)
  mentionsReceived Mention[] @relation("MentionMentioned")
  mentionsMade     Mention[] @relation("MentionMentioner")

  scheduledMessages ScheduledMessage[]

  @@map("users")
}

// ============================================================
// UNIVERSAL IDENTITY: Роли привязаны к контексту, не к пользователю
// Один user_id → много ролей в разных контекстах (system, workspace, circle)
// Пример: user A = ADMIN в system, STAFF в workspace X, GUEST в workspace Y
// ============================================================

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String // user, admin, moderator, owner, staff, manager, member, guest
  context   String // "system", "workspace", "circle"
  tenantId  String?  @map("tenant_id") // null для system-ролей, workspace_id или circle_id для контекстных
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by") // кто выдал роль (user_id)
  isActive  Boolean  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, context, tenantId]) // leading userId also serves plain userId lookups
  @@index([tenantId])
  @@index([userId, context])
  @@map("user_roles")
}

model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique // refresh token hash
  deviceInfo String?  @map("device_info")
  lastActive DateTime @default(now()) @map("last_active")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  plan      String   @default("free") // free, personal, family, business
  status    String   @default("trial") // active, trial, expired, cancelled
  expiresAt DateTime @map("expires_at")
  giftedBy  String?  @map("gifted_by") // user id who gifted
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@map("subscriptions")
}

// ============================================================
// CONTACTS & CIRCLES: Bilateral confirmed social graph
// ============================================================
// Architecture:
//   ContactLink       — a confirmed bilateral connection between two registered users
//                       (canonical ordering: userAId < userBId to keep unique constraint symmetric)
//                       Deleting a link is bilateral — the row is removed for both sides.
//   ContactInvitation — a pending request from one user to another (or to an unregistered phone).
//                       On acceptance, a ContactLink row is created and this row is marked accepted.
//                       External invitations (toUserId=null) auto-activate when the phone registers.
//   ContactBlock      — unidirectional block. A blocking B prevents B from inviting A again.
//   Circle            — an owner-local grouping (folder) of their confirmed contacts ("Семья", "Работа").
//                       A Circle belongs to one owner and contains ContactLinks via CircleMembership.
//   CircleMembership  — M2M join row: a ContactLink placed into a Circle by its owner.
//                       The SAME ContactLink can live in Circles owned by BOTH sides independently.
//
// Labels (roles like "жена", "друг") live on ContactLink as labelAForB / labelBForA —
// asymmetric so each side names the other how they want.
// Always-visible card fields: firstName, lastName, phone, role (label). Rest is per-field
// customizable via users.cardVisibility JSON on the card owner's side.
// ============================================================

model ContactLink {
  id          String   @id @default(uuid())
  // Canonical ordering: service layer MUST ensure userAId < userBId (string compare)
  // so (userAId, userBId) uniquely identifies the pair regardless of who initiated.
  userAId     String   @map("user_a_id")
  userBId     String   @map("user_b_id")
  // Asymmetric role: how each side names the other on their card.
  // ONE role per side. DB columns kept (label_*) to preserve data.
  roleAForB   String?  @map("label_a_for_b") // role A gave B (e.g. "Жена")
  roleBForA   String?  @map("label_b_for_a") // role B gave A (e.g. "Муж")
  // Who originally sent the invitation that created this link (user_id, not necessarily A)
  initiatedBy String   @map("initiated_by")
  confirmedAt DateTime @default(now()) @map("confirmed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userA       User               @relation("ContactLinkUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User               @relation("ContactLinkUserB", fields: [userBId], references: [id], onDelete: Cascade)
  memberships CircleMembership[]

  @@unique([userAId, userBId])
  // Composite indexes also satisfy `ORDER BY confirmedAt DESC` on the hot
  // "list my environment" query (which ORs over userAId / userBId). The
  // @@unique above already covers userAId-leading lookups.
  @@index([userAId, confirmedAt])
  @@index([userBId, confirmedAt])
  @@map("contact_links")
}

model ContactInvitation {
  id         String  @id @default(uuid())
  fromUserId String  @map("from_user_id")
  // Null when recipient is NOT yet on the platform (invitation by phone only).
  // Filled in when the phone registers → then the invitation is surfaced to them.
  toUserId   String? @map("to_user_id")
  toPhone    String  @map("to_phone") // normalized E.164

  // Roles each side proposes. Recipient can override at accept-time.
  // DB columns kept (proposed_label_*) to preserve data.
  proposedRoleForSender    String? @map("proposed_label_for_sender") // role recipient gives sender
  proposedRoleForRecipient String? @map("proposed_label_for_recipient") // role sender gives recipient
  message                  String? // optional greeting text

  // pending, accepted, rejected, cancelled, expired
  status      String    @default("pending")
  expiresAt   DateTime  @map("expires_at") // TTL — background job marks expired
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromUser User  @relation("InvitationSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User? @relation("InvitationRecipient", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toPhone])
  @@index([fromUserId, status]) // leading column also serves plain fromUserId lookups
  @@index([toUserId, status])
  // Send-path: cooldown / existing-pending checks filter (fromUserId, toPhone, status).
  @@index([fromUserId, toPhone, status])
  // Cleanup cron: WHERE status='pending' AND expiresAt < now.
  @@index([status, expiresAt])
  @@map("contact_invitations")
}

model ContactBlock {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("ContactBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("ContactBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("contact_blocks")
}

model Circle {
  id             String   @id @default(uuid())
  ownerId        String   @map("owner_id")
  name           String // "Семья", "Родственники", "Работа", custom
  icon           String?
  color          String?
  sortOrder      Int      @default(0) @map("sort_order")
  // Per-group card visibility — what members of THIS group may see.
  // null = use the owner's default (users.card_visibility).
  cardVisibility Json?    @map("card_visibility")
  // Per-group calendar access for THIS group's members (Phase 2): none | busy | detailed.
  calendarVisibility String @default("none") @map("calendar_visibility")
  // Per-group equipped card skin instance (premium). null = use owner's default skin.
  equippedSkinInstanceId String? @map("equipped_skin_instance_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  memberships   CircleMembership[]
  assignedTasks Task[]             @relation("TaskAssignedCircle")

  @@index([ownerId])
  @@map("circles")
}

model CircleMembership {
  id            String   @id @default(uuid())
  circleId      String   @map("circle_id")
  contactLinkId String   @map("contact_link_id")
  addedAt       DateTime @default(now()) @map("added_at")

  circle      Circle      @relation(fields: [circleId], references: [id], onDelete: Cascade)
  contactLink ContactLink @relation(fields: [contactLinkId], references: [id], onDelete: Cascade)

  @@unique([circleId, contactLinkId])
  @@index([contactLinkId])
  @@map("circle_memberships")
}

// ============================================================
// NOTIFICATIONS: generic cross-module notification feed
// ============================================================
// Used by every module. Type is a dot-namespaced string
// (contact.invitation.received, contact.invitation.accepted, task.assigned, etc.).
// Payload is a flexible JSON blob whose shape is defined per-type in @superapp/shared.

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String // e.g. "contact.invitation.received"
  title     String
  body      String?
  payload   Json? // flexible, shape depends on type
  actionUrl String?   @map("action_url") // deep link the client opens on tap
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // (createdAt, id) keyset so cursor pagination never skips/dupes rows that
  // share a created_at timestamp (EventBus fan-out can create several per ms).
  @@index([userId, createdAt, id])
  @@index([userId, readAt])
  @@map("notifications")
}

// ============================================================
// TASKS: Task Manager
// ============================================================

// Roles model (Bitrix24-style):
//   Постановщик  = creator (Task.creatorId, always 1, sets the task and accepts the result)
//   Исполнитель  = the single responsible executor          → TaskParticipant role="executor"
//   Соисполнитель = helpers (N)                              → TaskParticipant role="co_executor"
//   Наблюдатель   = watchers (N, read + chat only)           → TaskParticipant role="observer"
// An individual task has exactly ONE executor participant. A GROUP task (assignedCircleId set)
// has the circle members as co_executor participants — one shared task / one chat, but each
// participant carries their OWN status (drives "3 of 10" progress and per-person acceptance).
model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo") // todo, in_progress, on_review, done, cancelled
  priority    String    @default("medium") // low, medium, high, urgent
  // Numeric mirror of priority for ORDER BY (the string column sorts lexicographically:
  // high < low < medium < urgent — the visible "high below low" bug). 1=low … 4=urgent.
  priorityRank Int      @default(2) @map("priority_rank")
  dueDate     DateTime? @map("due_date")
  startDate   DateTime? @map("start_date")
  allDay      Boolean   @default(false) @map("all_day")

  // «Входящие» (GTD inbox): quick-add без срока/исполнителя, ещё не разобрано.
  // Уточнение (срок или исполнитель через PATCH) снимает флаг автоматически.
  inbox Boolean @default(false)

  // Постановщик (creator). Other roles live in TaskParticipant.
  creatorId String @map("creator_id")

  // Group assignment: when set, the task targets a Circle (Группа). The Исполнитель field
  // shows the circle's name; its members are co_executor participants. null = individual task.
  // Snapshot semantics: participants are materialised at creation; this only keeps the label.
  assignedCircleId String? @map("assigned_circle_id")

  // Hierarchy (subtasks)
  parentId String? @map("parent_id")
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("SubTasks")

  // Reward — display-only INTENT for now (no wallet yet; real balance lands with the Store).
  // Per-person semantics ("каждому по X"): coinReward is the amount each executor earns.
  coinReward   Int     @default(0) @map("coin_reward")
  coinPenalty  Int     @default(0) @map("coin_penalty")
  giftRewardId String? @map("gift_reward_id") // future: a gift from the owner's Store

  // Reminder (single reminder before the deadline for MVP; cron sends the notification).
  reminderAt     DateTime? @map("reminder_at")
  reminderSentAt DateTime? @map("reminder_sent_at")

  // Recurrence (RRULE-light, e.g. "FREQ=DAILY"). Generated instances point back via parent id.
  recurrenceRule     String? @map("recurrence_rule")
  recurrenceParentId String? @map("recurrence_parent_id")

  // Context — null = personal. workspaceId is the B2B tenant key (workspace assignment later).
  workspaceId String? @map("workspace_id")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  creator        User       @relation("TaskCreator", fields: [creatorId], references: [id])
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  assignedCircle Circle?    @relation("TaskAssignedCircle", fields: [assignedCircleId], references: [id], onDelete: SetNull)

  participants  TaskParticipant[]
  tags          TaskTag[]

  @@index([creatorId])
  @@index([workspaceId])
  @@index([status])
  @@index([dueDate])
  @@index([parentId])
  @@index([assignedCircleId])
  // Reminder cron scans WHERE reminderAt <= now AND reminderSentAt IS NULL.
  @@index([reminderAt])
  @@map("tasks")
}

model TaskParticipant {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  userId String @map("user_id")
  role   String // executor (Исполнитель), co_executor (Соисполнитель), observer (Наблюдатель)

  // Per-participant execution state. Acceptance is per-person, so a group task closes
  // ("done") only when EVERY non-observer participant reaches "accepted".
  //   pending → submitted (marked done) → accepted (creator accepted) | returned (sent back)
  status      String    @default("pending")
  submittedAt DateTime? @map("submitted_at")
  acceptedAt  DateTime? @map("accepted_at")
  returnedAt  DateTime? @map("returned_at")

  // Reward snapshot for this participant ("каждому по X"). Display-only for now.
  rewardCoins  Int     @default(0) @map("reward_coins")
  giftRewardId String? @map("gift_reward_id")

  addedAt DateTime @default(now()) @map("added_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId]) // one role per user per task
  @@index([userId, status]) // "tasks assigned to me" + filter by my state
  @@index([taskId, role])
  @@map("task_participants")
}

model TaskTag {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  name   String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, name])
  @@index([name])
  @@map("task_tags")
}

// ============================================================
// CALENDAR
// ============================================================

model CalendarEvent {
  id     String @id @default(uuid())
  userId String @map("user_id")

  title       String
  description String?
  location    String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  allDay      Boolean  @default(false) @map("all_day")
  color       String?

  // Per-event privacy override (sharing semantics wired in Phase 2): inherit | busy | hidden
  visibility String @default("inherit")

  // Configured reminder offsets (minutes before start). Materialized into CalendarEventReminder.
  reminderOffsets Int[] @map("reminder_offsets")

  // Recurrence (RRULE). Master rows carry recurrenceRule; single-occurrence overrides carry
  // recurrenceParentId + recurrenceId. exDates excludes occurrences from the master expansion.
  recurrenceRule     String?    @map("recurrence_rule")
  recurrenceParentId String?    @map("recurrence_parent_id")
  recurrenceId       DateTime?  @map("recurrence_id")
  exDates            DateTime[] @map("ex_dates")
  // Materialized end of the recurrence (last occurrence end from UNTIL/COUNT; null = infinite).
  // Lets range queries skip long-finished series instead of RRULE-expanding every master ever.
  recurrenceEndsAt   DateTime?  @map("recurrence_ends_at")

  // Future CalDAV two-way sync (unused in Phase 1)
  googleEventId    String? @map("google_event_id")
  googleCalendarId String? @map("google_calendar_id")

  // Resource booking (Phase 3): the resource this event holds + booking status (pending|confirmed|rejected).
  resourceId     String? @map("resource_id")
  resourceStatus String? @map("resource_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurrenceParent CalendarEvent?          @relation("EventRecurrence", fields: [recurrenceParentId], references: [id], onDelete: Cascade)
  overrides        CalendarEvent[]         @relation("EventRecurrence")
  reminders        CalendarEventReminder[]
  participants     EventParticipant[]
  resource         Resource?               @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@index([userId, startTime])
  @@index([recurrenceParentId])
  @@index([googleEventId])
  @@index([resourceId])
  @@map("calendar_events")
}

// A bookable shared resource (room, vehicle, equipment). Personal for now (owner = user);
// workspaceId reserved for future B2B. Bookings are CalendarEvents referencing it.
model Resource {
  id              String   @id @default(uuid())
  ownerId         String   @map("owner_id")
  workspaceId     String?  @map("workspace_id")
  name            String
  type            String   @default("other") // room | vehicle | equipment | other
  capacity        Int      @default(1)
  // Allow-list of who may book: specific people + Groups from the owner's environment.
  bookerUserIds   String[] @map("booker_user_ids")
  bookerCircleIds String[] @map("booker_circle_ids")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  owner    User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings CalendarEvent[]

  @@index([ownerId])
  @@map("resources")
}

// Materialized reminder queue: one row per (event occurrence × configured offset × user).
// Rolling horizon kept by the calendar cron; dispatched rows emit calendar.event.reminder.
model CalendarEventReminder {
  id              String    @id @default(uuid())
  eventId         String    @map("event_id")
  userId          String    @map("user_id")
  occurrenceStart DateTime  @map("occurrence_start")
  minutesBefore   Int       @map("minutes_before")
  fireAt          DateTime  @map("fire_at")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, occurrenceStart, minutesBefore])
  @@index([fireAt, sentAt])
  @@map("calendar_event_reminders")
}

// Event attendees (Phase 2). The creator is the implicit organizer (event.userId);
// rows here are invitees. One shared event → many participants (no copies).
model EventParticipant {
  id      String   @id @default(uuid())
  eventId String   @map("event_id")
  userId  String   @map("user_id")
  role    String   @default("attendee") // organizer | attendee
  rsvp    String   @default("pending") // pending | accepted | declined | tentative
  // This participant's own reminder offsets (minutes before start). Materialized per user.
  reminderOffsets Int[] @map("reminder_offsets")
  addedAt DateTime @default(now()) @map("added_at")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_participants")
}

// Personal calendar shares migrated to the access engine (core/access) — CalendarShare dropped.

// Per-user Google Calendar connection (Phase 4 two-way sync). One Google account per user.
// NOTE: tokens are stored as-is for MVP; encrypt-at-rest before production.
model GoogleConnection {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  googleEmail       String    @map("google_email")
  accessToken       String    @map("access_token")
  refreshToken      String    @map("refresh_token")
  tokenExpiry       DateTime? @map("token_expiry")
  // Google calendar we two-way sync events with; separate calendar for one-way task export.
  syncCalendarId    String?   @map("sync_calendar_id")
  tasksCalendarId   String?   @map("tasks_calendar_id")
  // Incremental sync state + push-notification channel.
  syncToken         String?   @map("sync_token")
  channelId         String?   @map("channel_id")
  channelResourceId String?   @map("channel_resource_id")
  channelExpiry     DateTime? @map("channel_expiry")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_connections")
}

// ============================================================
// WORKSPACES (Job platform foundation)
// ============================================================

// A Workspace is ALWAYS a business/organization (B2B tenant). Personal life is the
// social graph (workspaceId = null), NOT a workspace — so there is no "type" field.
model Workspace {
  id   String  @id @default(uuid())
  name String
  logo String?

  // Company profile (Анкета) — fields rendered on the company card.
  description    String? // "О компании"
  industry       String? // отрасль
  city           String?
  website        String?
  contactEmail   String? @map("contact_email")
  contactPhone   String? @map("contact_phone")
  // Default visibility of card fields to members (employees). null = defaults
  // (see DEFAULT_WORKSPACE_CARD_VISIBILITY in @superapp/shared). Always-visible: name, logo.
  cardVisibility Json?   @map("card_visibility")

  ownerId  String  @map("owner_id") // founder; single owner (billing/delete/transfer)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner       User                  @relation(fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  tasks       Task[]
  staffDepartments StaffDepartment[]
  staffPositions   StaffPosition[]
  staffBranches    StaffBranch[]
  staffAssignments StaffAssignment[]

  @@index([ownerId])
  @@map("workspaces")
}

// Membership row. Role & permissions are NOT stored here — the single source
// of truth is UserRole (context="workspace", tenantId=workspaceId). Должности/отделы/
// филиалы — сущности StaffModule (назначения в StaffAssignment), не текст здесь.
model WorkspaceMember {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  userId      String @map("user_id")

  joinedAt DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

// Hiring invitation. Найм ВСЕГДА в Стажёра (роль не выбирается; колонка остаётся для
// истории/будущих типов найма). Опциональные positionId + branchIds — «нанять официанта
// в Алматинский и Астанинский филиалы»: при принятии создаётся назначение на КАЖДЫЙ
// филиал (один сотрудник может обслуживать несколько). branchIds — scalar-массив (FK на
// массив в Postgres нет; мёртвый id безопасно скипается при принятии).
// toUserId is null for an external invite by phone — it activates when that phone registers.
model WorkspaceInvitation {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  invitedBy   String @map("invited_by") // user_id who sent the invite

  toUserId String? @map("to_user_id") // null until the invited phone is on the platform
  toPhone  String  @map("to_phone") // normalized E.164

  role       String   @default("trainee") // всегда trainee для новых приглашений
  positionId String?  @map("position_id")
  branchIds  String[] @map("branch_ids") // несколько филиалов «с порога»
  message    String?

  status      String    @default("pending") // pending, accepted, rejected, cancelled, expired
  expiresAt   DateTime  @map("expires_at") // TTL — background job marks expired
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User           @relation("WsInvitationInviter", fields: [invitedBy], references: [id], onDelete: Cascade)
  toUser    User?          @relation("WsInvitationRecipient", fields: [toUserId], references: [id], onDelete: Cascade)
  position  StaffPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([toUserId])
  @@index([toPhone])
  @@index([workspaceId, status])
  @@index([toUserId, status])
  // Cleanup cron: WHERE status='pending' AND expiresAt < now.
  @@index([status, expiresAt])
  @@map("workspace_invitations")
}

// ============================================================
// STAFF («Сотрудники») — справочники организации + назначения должностей
// ============================================================
// Должность/Отдел/Филиал — первоклассные справочники воркспейса. Назначение =
// человек × должность × (опц.) филиал со статусом обучения (Додзё переключит
// training→certified). Членство в отделе — ПРОИЗВОДНОЕ от должности
// (StaffPosition.departmentId) — модель штатного расписания 1С. Роль прав
// (trainee/staff/manager/…) живёт в UserRole, справочники прав не несут.
// Рёбра проецируются в core/access: position#holder / branch#member / department#member.

model StaffDepartment {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  name        String
  parentId    String? @map("parent_id") // дерево в данных; UI пока плоский список
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    StaffDepartment?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  StaffDepartment[] @relation("DepartmentTree")
  positions StaffPosition[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("staff_departments")
}

model StaffPosition {
  id           String  @id @default(uuid())
  workspaceId  String  @map("workspace_id")
  name         String
  departmentId String? @map("department_id") // отдел должности (опционально)
  description  String?
  sortOrder    Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department  StaffDepartment?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignments StaffAssignment[]
  invitations WorkspaceInvitation[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([departmentId])
  @@map("staff_positions")
}

model StaffBranch {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  name        String
  address     String?
  note        String?
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments StaffAssignment[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("staff_branches")
}

// Назначение должности. Несколько на человека — норма (официант + бармен; одна
// должность в двух филиалах = два назначения). Сервис не даёт дубликат
// (workspace,user,position,branch); для branch IS NULL дубль закрывает partial
// unique index в миграции (Postgres считает NULL различными).
model StaffAssignment {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  userId      String  @map("user_id")
  positionId  String  @map("position_id")
  branchId    String? @map("branch_id")
  status      String  @default("training") // training | certified (Додзё/manager+ переключает)
  assignedBy  String? @map("assigned_by") // user_id назначившего (аудит)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  position  StaffPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  branch    StaffBranch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId, positionId, branchId])
  @@index([workspaceId, userId])
  @@index([positionId])
  @@index([branchId])
  @@map("staff_assignments")
}

// ============================================================
// WALLET — currencies, typed accounts, immutable double-entry journal, escrow
// ============================================================
// Real-money-grade ledger (NOT a bank — but correct enough that real money via a future bank
// top-up can flow through it): a chart of typed Accounts, double-entry transfers (every movement
// balances within one currency), two-phase holds (pending → post/void), integer minor units with
// a per-currency scale, and no negative balances on user wallets.

// An issued currency. Exactly ONE active currency per issuer. Polymorphic issuer (user now;
// workspace later) → issuerId validated in the service, not an FK. Name/icon referenced by id
// everywhere (rename is retroactive, ≤1×/3 months). Deletion = soft-delete. `scale` is the
// ISO-4217-style minor-unit exponent (0 = whole coins; 2 = tenge/tiyin) — amounts are always
// integer minor units. `code` is an optional fiat code (e.g. 'KZT'); null for personal coins.
model Currency {
  id           String @id @default(uuid())
  issuerType   String @map("issuer_type") // 'user' | 'workspace'
  issuerId     String @map("issuer_id")
  name         String
  icon         String // emoji, no ticker
  code         String? // optional ISO-4217-style code for fiat (e.g. 'KZT'); null for personal coins
  scale        Int    @default(0) // minor-unit exponent: 0 = whole coins, 2 = tenge/tiyin
  currencyType String @default("CUSTOM_COIN") @map("currency_type") // CUSTOM_COIN | FIAT…

  // B2B hook: who may see holders' balances (role/position matrix). null = personal rule
  // (balance visible to holder + issuer only). Unused this phase.
  visibilityPolicy Json? @map("visibility_policy")

  status        String    @default("active") // active | deleted
  lastRenamedAt DateTime? @map("last_renamed_at") // enforces the 1×/3-months rename limit

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  accounts Account[]

  // "One active currency per issuer" is a PARTIAL unique index (WHERE status='active')
  // added in the migration — Prisma can't express partial uniques in-schema.
  @@index([issuerType, issuerId])
  @@index([status])
  @@map("currencies")
}

// Chart of accounts. Every balance is an Account of a TYPE — double-entry, so money never appears
// or vanishes: it only moves between accounts.
//   user      — a holder's wallet (a liability: we owe them this balance).
//   issuance  — the source coins are minted FROM (allowNegative: its balance goes negative by the
//               amount in circulation, offsetting all user balances → per-currency Σ = 0).
//   escrow / fee / external — reserved for later (marketplace fees, bank top-up/withdrawal rails).
// `balance` (posted, credit-normal: +credit / −debit) and `held` (Σ of this account's unresolved
// pending OUTGOING reservations) are a materialized cache; the journal is the truth. Row-locked on
// spend. available = balance − held; user wallets may not go negative (allowNegative = false).
// For system accounts (issuance/external/fee) ownerId = the currencyId (one per currency).
model Account {
  id         String  @id @default(uuid())
  currencyId String  @map("currency_id")
  type       String // user | issuance | escrow | fee | external
  ownerType  String  @map("owner_type") // user | workspace | system
  ownerId    String  @map("owner_id") // userId / workspaceId; system accounts use the currencyId

  balance       BigInt  @default(0) // posted net (credit-normal)
  held          BigInt  @default(0) // Σ unresolved pending outgoing reservations
  allowNegative Boolean @default(false) @map("allow_negative")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  currency Currency @relation(fields: [currencyId], references: [id])

  @@unique([currencyId, type, ownerType, ownerId]) // one account per (currency, type, owner)
  @@index([ownerType, ownerId])
  @@index([currencyId, type])
  @@map("accounts")
}

// Immutable, append-only double-entry journal — the single source of truth for every balance. Rows
// are never updated or deleted; corrections are compensating rows. FK-free (hot writes; integrity
// enforced in LedgerService). Monotonic bigint PK (append-log ordering). Each row moves `amount`
// (positive integer minor units) from debitAccount to creditAccount within one currency. kind:
//   posted        — settles now (mint, P2P, payout, burn).
//   pending       — a hold/authorization: reserves on the debit account (held += amount) without
//                   settling. The escrow "freeze".
//   post_pending  — settles a prior pending (pendingId set); `amount` ≤ the pending amount.
//   void_pending  — cancels a prior pending (pendingId set): releases the reservation.
model LedgerTransfer {
  id              BigInt   @id @default(autoincrement())
  currencyId      String   @map("currency_id")
  debitAccountId  String   @map("debit_account_id")
  creditAccountId String   @map("credit_account_id")
  amount          BigInt // positive integer minor units
  kind            String // posted | pending | post_pending | void_pending
  pendingId       BigInt?  @map("pending_id") // the pending row this posts/voids
  agreementId     String?  @map("agreement_id") // origin escrow agreement (task / order)
  idempotencyKey  String?  @unique @map("idempotency_key") // duplicate event collides here
  memo            String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([debitAccountId, id]) // history + balance recompute
  @@index([creditAccountId, id])
  @@index([currencyId])
  @@index([pendingId])
  @@index([agreementId])
  @@map("ledger_transfers")
}

// "Сделка" — an escrow agreement: the first-class grouping of the per-leg holds for ONE source
// (a task or a marketplace order). Thin by design: a status + a grouping anchor only. Crowdfunding
// target/progress are NOT stored here (a price can be multi-currency, e.g. 100🍎+50🌟, so a single
// number can't express the target) — the target lives on the priced source (the listing) and
// "collected" is Σ of the active holds per currency. The generic escrow engine (wallet) owns this;
// Tasks and Commerce are its two clients. refType discriminates the source kind.
model EscrowAgreement {
  id        String   @id @default(uuid())
  refType   String   @map("ref_type") // 'task' | 'order'
  refId     String   @map("ref_id") // the task / order id
  status    String   @default("open") // open | settled | refunded | cancelled
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  holds EscrowHold[]

  @@unique([refType, refId]) // exactly one agreement per source; also serves lookups
  @@index([status])
  @@map("escrow_agreements")
}

// One leg of an agreement, backed by a two-phase transfer in the journal. The "freeze" is a
// `pending` transfer payer→beneficiary (reserves on the payer's account, no settlement yet). status
// mirrors the transfer: active (pending live) → captured (post_pending settled the payout) →
// released (void_pending refunded the reservation). `pendingTransferId` links the live pending row;
// `postedTransferId` is set on capture. A released leg can be re-activated (idempotent re-fund).
// One leg per (agreement, payer, beneficiary, currency): a task funds one leg per worker (payer =
// creator, single currency); a marketplace order funds one leg per payer × currency (crowdfunding =
// many payers; cross-currency price = many currencies; beneficiary = the seller).
model EscrowHold {
  id                String   @id @default(uuid())
  agreementId       String   @map("agreement_id")
  currencyId        String   @map("currency_id")
  payerUserId       String   @map("payer_user_id") // whose coins are frozen (user id, or workspace id if payerType=workspace)
  payerType         String   @default("user") @map("payer_type") // user | workspace (company treasury, B2B P9)
  beneficiaryUserId String   @map("beneficiary_user_id") // who is paid on capture (user id, or workspace id if beneficiaryType=workspace)
  beneficiaryType   String   @default("user") @map("beneficiary_type") // user | workspace (company treasury, B2B P9)
  amount            BigInt
  status            String   @default("active") // active | captured | released
  pendingTransferId BigInt?  @map("pending_transfer_id") // the live pending transfer (the freeze)
  postedTransferId  BigInt?  @map("posted_transfer_id") // the post_pending settlement (enables collect-back)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agreement EscrowAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@unique([agreementId, payerUserId, beneficiaryUserId, currencyId]) // one leg per tuple; idempotent
  @@index([payerUserId, currencyId, status]) // "what I froze"
  @@index([currencyId, status]) // deleteCurrency release sweep
  @@index([agreementId, status]) // capture / release by agreement
  @@index([beneficiaryUserId, status])
  @@map("escrow_holds")
}

// ============================================================
// MY WISH & SHOP — shops, showcases, listings (Phase 2: catalog skeleton)
// ============================================================
// A personal/company storefront. 1 shop per owner (lazily created). Owner is polymorphic
// (user|workspace) — B2B isolation is by explicit ownership + authorization (NOT the workspace
// chokepoint; a shop is accessed by id, not as implicit "my data"). Staff are NOT here — they are
// UserRole rows (context 'shop'/'showcase'). Buying/escrow is Phase 3; the catalog lives here.
model Shop {
  id        String  @id @default(uuid())
  ownerType String  @map("owner_type") // 'user' | 'workspace'
  ownerId   String  @map("owner_id")
  name      String? // display name; null → fall back to the owner's name
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  showcases Showcase[]

  @@unique([ownerType, ownerId]) // one shop per owner
  @@map("shops")
}

// A "Витрина": a folder of listings inside a shop, switched in the left rail. Visibility is shared
// per-showcase to people and/or Circle Groups (mirrors calendar/card sharing) via the access
// engine (core/access); no grants → visible only to the owner + staff (no separate "draft" flag).
model Showcase {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  name      String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop     Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@index([shopId])
  @@map("showcases")
}

// Showcase audiences migrated to the access engine (core/access) — ShowcaseShare dropped.
// Showcase visibility is now `showcase:<id>#viewer@user|circle#member` tuples.

// A lot. Full schema now; Phase 2 wires only catalog CRUD + display. Behaviour is added in later
// phases: purchase/escrow (P3), task/calendar fulfilment (P4), cross-currency price (P5),
// crowdfunding (P6), stock + time window + FOMO discount + auto-archive (P7), wishlist copy (P8).
model Listing {
  id          String  @id @default(uuid())
  showcaseId  String  @map("showcase_id")
  title       String
  description String?
  icon        String? // emoji from the standard set
  itemType    String  @default("material") @map("item_type") // material | nonmaterial
  withTask    Boolean @default(false) @map("with_task") // creates a Task/Event on purchase (P4)
  taskDays    Int?    @map("task_days") // days to fulfil when withTask
  crowdfunding Boolean @default(false) // joint fundraising on the card (P6)

  // Availability (P7 behaviour; fields now). stockLimit null = infinite.
  stockLimit     Int?      @map("stock_limit")
  stockSold      Int       @default(0) @map("stock_sold")
  availableFrom  DateTime? @map("available_from")
  availableUntil DateTime? @map("available_until")
  discountPercent Int?     @map("discount_percent") // FOMO discount
  discountUntil   DateTime? @map("discount_until")

  status           String  @default("active") // active | archived
  sourceWishItemId String? @map("source_wish_item_id") // origin wishlist item when copied (P8)
  sortOrder        Int     @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  showcase Showcase       @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  prices   ListingPrice[]
  orders   Order[]

  @@index([showcaseId, status])
  @@index([sourceWishItemId])
  @@map("listings")
}

// A price line item: the lot costs `amount` of `currencyId`. Multiple rows = combined cross-currency
// price (P5); Phase 2 uses a single line in the owner's own currency. FK-free to Currency (validated).
model ListingPrice {
  id         String @id @default(uuid())
  listingId  String @map("listing_id")
  currencyId String @map("currency_id")
  amount     BigInt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, currencyId])
  @@index([currencyId])
  @@map("listing_prices")
}

// A purchase (Phase 3+5). One order = one listing, single buyer; the price is a SNAPSHOT of N
// currency lines (OrderPrice) — one line per currency (cross-currency = P5; single line in Phase 3).
// The price is held in escrow (EscrowAgreement refType='order', refId=order.id) as one leg per
// currency: frozen on placement, captured on confirm (instant items) or on task completion (material
// «с задачей», P4), refunded on reject/cancel. listingId is nullable (onDelete SetNull) so an order
// survives as history if its listing is later deleted — the title and price are snapshotted. seller =
// the shop owner (the coins' beneficiary), even when a co-manager confirms.
model Order {
  id            String    @id @default(uuid())
  listingId     String?   @map("listing_id")
  titleSnapshot String    @map("title_snapshot")
  showcaseId    String    @map("showcase_id")
  shopId        String    @map("shop_id")
  buyerId       String    @map("buyer_id") // single buyer; for crowdfunding = the campaign initiator
  sellerId      String    @map("seller_id") // shop owner = escrow beneficiary (B2C: a user)
  status        String    @default("pending") // funding(P6) | pending | confirmed | settled | rejected | cancelled | refunded
  crowdfunding  Boolean   @default(false) // snapshot: a joint-funded campaign (P6) — see OrderContribution
  itemType      String    @map("item_type") // snapshot: material | nonmaterial
  withTask      Boolean   @default(false) @map("with_task") // snapshot
  taskId        String?   @map("task_id") // fulfilment task (P4, material «с задачей»)
  taskDays      Int?      @map("task_days") // snapshot: days to fulfil → the auto-task due date
  eventId       String?   @map("event_id") // calendar event (P4, non-material «с задачей»)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  confirmedAt   DateTime? @map("confirmed_at")
  closedAt      DateTime? @map("closed_at") // settled / rejected / cancelled
  expiresAt     DateTime? @map("expires_at") // crowdfunding campaign deadline (P7); null = no auto-expiry

  listing       Listing?            @relation(fields: [listingId], references: [id], onDelete: SetNull)
  prices        OrderPrice[]
  contributions OrderContribution[]

  @@index([shopId, status])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([listingId])
  @@index([taskId])
  @@map("orders")
}

// A pledge toward a crowdfunding campaign (P6): contributor freezes `amount` of `currencyId` (one
// escrow leg, payer=contributor → beneficiary=owner) under the campaign Order. Cross-currency goal →
// a contributor's pledge can span currencies (one row each). FK to Order cascade; FK-free to Currency
// (validated). All-or-nothing: legs captured to the owner only when EVERY goal currency is filled.
model OrderContribution {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  contributorId String   @map("contributor_id")
  currencyId    String   @map("currency_id")
  amount        BigInt
  createdAt     DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, contributorId, currencyId])
  @@index([orderId])
  @@index([contributorId])
  @@map("order_contributions")
}

// A wishlist item (Phase 8): something the OWNER wants. No price — a person from the owner's
// окружение turns it into a priced Listing in THEIR OWN shop (Listing.sourceWishItemId links back),
// so the wish auto-fulfils when that lot settles. The wishlist is shared to people/Groups via the
// access engine (resource `wishlist:<ownerId>`). itemType (material/nonmaterial) is set by the owner.
model WishItem {
  id          String    @id @default(uuid())
  ownerId     String    @map("owner_id")
  title       String
  description String?
  icon        String?
  link        String? // a URL the owner wants (optional)
  itemType    String    @default("material") @map("item_type") // material | nonmaterial
  status      String    @default("active") // active | fulfilled | archived
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  fulfilledAt DateTime? @map("fulfilled_at")

  @@index([ownerId, status])
  @@map("wish_items")
}

// A snapshotted price line of an order: the buyer pays `amount` of `currencyId`. Multiple rows =
// cross-currency price (P5). Mirrors ListingPrice and is FK-free to Currency (validated, not
// constrained) so a later currency deletion can't block order history. Each line is one escrow leg.
model OrderPrice {
  id         String @id @default(uuid())
  orderId    String @map("order_id")
  currencyId String @map("currency_id")
  amount     BigInt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, currencyId])
  @@index([currencyId])
  @@map("order_prices")
}

// ============================================================
// ACCESS: Unified authorization engine (ReBAC) — core/access
// ============================================================
// One uniform store of relationship tuples: "subject has <relation> on <resource>".
//   resourceType:resourceId # relation @ subjectType:subjectId(#subjectRelation)
// Permissions are DERIVED from these tuples + per-resource-type rewrite rules
// (core/access/access-schema.ts) — never stored. Pure-sharing data (CalendarShare,
// ShowcaseShare) migrates here (Phase 2); domain membership/roles are PROJECTED here
// and kept in sync (Phase 1). Cross-cutting — deliberately NOT in the workspace chokepoint.
//
//   subjectRelation = ""        → the subject is named directly (a user, or an object
//                                 such as a parent pointer showcase#parent@shop).
//   subjectRelation = "member"  → a userset: every subject holding that relation on the
//                                 subject object, e.g. circle:fam#member (all members of fam).
// ============================================================
// MESSENGER: Chats, members, messages (Phase 1: DM + spine)
// ============================================================

model Chat {
  id String @id @default(uuid())

  // dm | group | context
  type String @default("dm")

  // Canonical "minUserId:maxUserId" for DMs (unique → exactly one DM per pair). Null otherwise.
  dmKey String? @unique @map("dm_key")

  // Polymorphic parent for CONTEXT chats (null for DM/group).
  // parentType: task | calendar_event | listing | order | ...
  parentType String? @map("parent_type")
  parentId   String? @map("parent_id")

  // Creator/owner of an ad-hoc group chat (null for dm/context). Owner has full management.
  createdById String? @map("created_by_id")

  // B2B scoping (mirrors Task). Null = personal. Not chokepoint-scoped yet (B2B phase).
  workspaceId String? @map("workspace_id")

  // Optional display title (group chats); DM/context derive it from peer/parent.
  title String?

  // Monotonic per-chat message counter; assigned to Message.seq under row lock.
  lastSeq Int @default(0) @map("last_seq")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members           ChatMember[]
  messages          Message[]
  scheduledMessages ScheduledMessage[]

  @@index([type])
  // One context chat per parent (e.g. one chat per task). Postgres treats NULLs as
  // distinct, so DM/group chats (parentType/parentId NULL) are exempt and unconstrained.
  @@unique([parentType, parentId])
  @@index([workspaceId])
  @@map("chats")
}

model ChatMember {
  id     String @id @default(uuid())
  chatId String @map("chat_id")
  userId String @map("user_id")

  // owner | admin | member | bot (group management + display)
  role String @default("member")

  // History floor: this member only sees messages with seq >= visibleFromSeq.
  // Set to chat.lastSeq when added to a group (WhatsApp-style join-point history); 0 = full history (DM, task chat).
  visibleFromSeq Int @default(0) @map("visible_from_seq")

  // Read-cursor model (D6): how far messages were delivered / read for this user.
  deliveredSeq Int       @default(0) @map("delivered_seq")
  deliveredAt  DateTime? @map("delivered_at")
  lastReadSeq  Int       @default(0) @map("last_read_seq")
  lastReadAt   DateTime? @map("last_read_at")

  // Per-user chat state.
  mutedUntil DateTime? @map("muted_until")
  pinned     Boolean   @default(false)
  archived   Boolean   @default(false)

  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId, archived])
  @@map("chat_members")
}

model Message {
  id     String @id @default(uuid())
  chatId String @map("chat_id")

  // Null for system messages (no human author).
  authorId String? @map("author_id")

  // text | system | rich_card
  type String @default("text")

  // Plain text for text messages; JSON payload for system/rich_card.
  content String?
  payload Json?

  // Per-chat monotonic order; assigned from Chat.lastSeq under row lock.
  seq Int

  // Reply/quote (Phase 7): the message this one quotes (self-relation; null = not a reply).
  replyToId String? @map("reply_to_id")

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")

  chat    Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author  User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  replyTo Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MessageReply")

  @@unique([chatId, seq]) // also serves (chatId, seq) range scans — no separate index needed
  @@index([authorId])
  @@map("messages")
}

// ============================================================
// SCHEDULED MESSAGES (Phase 7, "Напомнить"): a message the author schedules to be
// sent into a chat at a future time. A cron fires due ones → posts a normal Message
// from the author + pings the author. The author can view/edit/cancel while pending.
// ============================================================
model ScheduledMessage {
  id       String @id @default(uuid())
  chatId   String @map("chat_id")
  authorId String @map("author_id")

  content String
  // Optional quote carried into the eventual message.
  replyToId String? @map("reply_to_id")

  // When to send.
  sendAt DateTime @map("send_at")

  // pending | sending (claimed by a firing cron — transient) | sent | cancelled
  status String @default("pending")
  // The Message created when it fired (audit / dedup).
  sentMessageId String? @map("sent_message_id")

  createdAt DateTime @default(now()) @map("created_at")
  // @default(now()) mirrors the DB's `DEFAULT CURRENT_TIMESTAMP` (created in raw SQL)
  // so `migrate dev` sees no drift; @updatedAt keeps the app-side bump on write.
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Cron scan: due pending rows.
  @@index([status, sendAt])
  @@index([chatId, authorId])
  @@map("scheduled_messages")
}

// ============================================================
// MENTIONS HUB (Phase 5): every @mention of a user, across services, in one feed.
// Mentions are PICK-from-members (users have no @username) → the mentioned user is a
// resolved id, not a parsed name. A `mention.received` Notification fires alongside.
// ============================================================
model Mention {
  id String @id @default(uuid())

  mentionedUserId String @map("mentioned_user_id")
  mentionerUserId String @map("mentioner_user_id")

  // Where it happened: messenger | task | calendar | listing (generic, reusable).
  sourceType String @map("source_type")
  // The primary entity id for the deep link (chatId for messenger, taskId, eventId…).
  sourceId   String @map("source_id")

  // Messenger specifics (null for non-chat sources) — used for the in-context jump.
  chatId    String? @map("chat_id")
  messageId String? @map("message_id")

  // Short text context for the hub row.
  snippet String?

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  mentionedUser User @relation("MentionMentioned", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  mentioner     User @relation("MentionMentioner", fields: [mentionerUserId], references: [id], onDelete: Cascade)

  // One mention per (message, mentioned user) so re-edits don't duplicate.
  @@unique([messageId, mentionedUserId])
  @@index([mentionedUserId, createdAt])
  @@index([sourceType, sourceId])
  @@map("mentions")
}

// ============================================================
// SEARCH INDEX (Phase 6): denormalized, permission-trimmed search "витрина" for the
// unified core/search engine. One row per searchable item across services (messenger
// now; tasks/events/etc. later). The index is a PROJECTION — domain tables stay the
// source of truth; rows are kept fresh by best-effort hooks + a reconcile cron + a
// backfill script (same pattern as core/access). FTS (generated `tsvector`, 'russian'
// config for word-form stemming) + pg_trgm GIN (typo/substring/name match, language-
// agnostic for KZ/EN) live in raw SQL (the migration); SearchService queries via $queryRaw.
// ============================================================
model SearchDocument {
  id String @id @default(uuid())

  // Provider/source kind: message | chat | (task | event | wish … later).
  sourceType String @map("source_type")
  // The domain entity id this row mirrors.
  sourceId   String @map("source_id")

  // B2B scoping (null = personal/social). Mirrors the entity's workspace.
  workspaceId String? @map("workspace_id")

  // Searchable text: title (chat name, task title…) + body (message text, description…).
  title String?
  body  String?

  // Deep link to open the result.
  url String

  // Access keys (provider-specific, used to permission-trim at query time):
  // message/chat → chatId; message → seq (vs ChatMember.visibleFromSeq); author for display.
  chatId   String? @map("chat_id")
  seq      Int?
  authorId String? @map("author_id")

  // The ENTITY's timestamp (NOT row-insert time) — drives recency ranking.
  itemCreatedAt DateTime @map("item_created_at")

  createdAt DateTime @default(now()) @map("created_at")
  // @default(now()) mirrors the DB's `DEFAULT CURRENT_TIMESTAMP` (created in raw SQL)
  // so `migrate dev` sees no drift; @updatedAt keeps the app-side bump on write.
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Generated FTS column (Postgres `GENERATED ALWAYS AS (...) STORED`), maintained by
  // the DB and never written by Prisma (Unsupported fields are excluded from writes).
  // Prisma's schema-engine reads a generated column's expression as a column DEFAULT, so
  // declaring the SAME expression via @default(dbgenerated(...)) makes `migrate dev` see
  // no drift (otherwise it emits a failing `ALTER COLUMN ... DROP DEFAULT`). The string is
  // Prisma's own round-tripped form of the expression in migrations/20260601160000_search.
  searchVector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('russian'::regconfig, ((COALESCE(title, ''::text) || ' '::text) || COALESCE(body, ''::text)))")) @map("search_vector")

  @@unique([sourceType, sourceId])
  @@index([sourceType])
  @@index([chatId])
  // GIN indexes created in raw SQL (migrations/20260601160000_search) — declared here so
  // `migrate dev` does not try to drop them. trgm for typo/substring/name matching; the
  // searchVector GIN (default tsvector_ops) backs FTS ranking.
  @@index([title(ops: raw("gin_trgm_ops"))], map: "search_documents_title_trgm_idx", type: Gin)
  @@index([body(ops: raw("gin_trgm_ops"))], map: "search_documents_body_trgm_idx", type: Gin)
  @@index([searchVector], type: Gin)
  @@map("search_documents")
}

model RelationTuple {
  id              String   @id @default(uuid())
  resourceType    String   @map("resource_type")
  resourceId      String   @map("resource_id")
  relation        String
  subjectType     String   @map("subject_type")
  subjectId       String   @map("subject_id")
  subjectRelation String   @default("") @map("subject_relation")
  createdAt       DateTime @default(now()) @map("created_at")

  // One row per distinct edge. subjectRelation defaults to "" (never NULL) so the unique
  // constraint is deterministic for direct subjects (avoids Postgres NULL-distinct gotcha).
  @@unique([resourceType, resourceId, relation, subjectType, subjectId, subjectRelation])
  // Forward walk: who has <relation> on <resource> (expand a resource's relation).
  @@index([resourceType, resourceId, relation])
  // Reverse walk: every edge a subject appears in (group expansion, parent pointers, listObjects).
  @@index([subjectType, subjectId])
  // listObjects fast path: resources of a type where a subject is named for a relation.
  @@index([subjectType, subjectId, resourceType, relation])
  @@map("relation_tuples")
}

// ============================================================
// CARD SKINS — cosmetic skins for PersonCard (platform-sold)
//
// CardSkin = the DESIGN/type (tokens + layer assets, rarity, price, supply).
// CardSkinInstance = an owned copy ("real item"): serial for limited skins,
//   transfer history → future gift/trade. Purchases use the platform currency
//   via the Ledger (issuerType='platform'); no escrow (instant), trade later.
// ============================================================

model CardSkin {
  id          String  @id @default(uuid())
  name        String
  description String?
  // Author of the design — shown nowhere in UI; set manually for collabs.
  authorId    String? @map("author_id")
  rarity      String  @default("common") // common|uncommon|rare|epic|legendary|mythic
  priceAmount BigInt  @default(0) @map("price_amount") // platform-currency minor units

  // Supply: null = unlimited; a number = limited tirage. `minted` counts issued copies
  // (drives serial numbers and sold-out). Optional sales window.
  supply         Int?
  minted         Int       @default(0)
  availableFrom  DateTime? @map("available_from")
  availableUntil DateTime? @map("available_until")

  // Render layers — tokens (CardSkinTokens JSON) + optional assets. Skin = DATA.
  tokens        Json
  decor         String  @default("none") // 'crayon' | 'none'
  frameUrl      String? @map("frame_url")
  backgroundUrl String? @map("background_url")
  effectUrl     String? @map("effect_url") // Lottie JSON URL
  schemaVersion Int     @default(1) @map("schema_version")

  status    String   @default("active") // active | archived
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  instances CardSkinInstance[]

  @@index([status])
  @@map("card_skins")
}

model CardSkinInstance {
  id            String   @id @default(uuid())
  skinId        String   @map("skin_id")
  ownerId       String   @map("owner_id")
  serial        Int? // only set for limited skins (#N of supply)
  acquiredVia   String   @default("purchase") @map("acquired_via") // purchase | gift | trade | grant
  schemaVersion Int      @default(1) @map("schema_version")
  createdAt     DateTime @default(now()) @map("created_at")

  skin      CardSkin           @relation(fields: [skinId], references: [id], onDelete: Cascade)
  transfers CardSkinTransfer[]

  @@index([ownerId])
  @@index([skinId])
  // Defense-in-depth: a limited skin can't issue the same serial twice. NULL serials
  // (unlimited skins) are treated as distinct by Postgres, so they're unaffected.
  @@unique([skinId, serial], map: "card_skin_instances_skin_serial_key")
  @@map("card_skin_instances")
}

model CardSkinTransfer {
  id         BigInt   @id @default(autoincrement())
  instanceId String   @map("instance_id")
  fromUserId String?  @map("from_user_id") // null = minted by the platform
  toUserId   String   @map("to_user_id")
  kind       String // mint | gift | trade | sale
  createdAt  DateTime @default(now()) @map("created_at")

  instance CardSkinInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("card_skin_transfers")
}

// ============================================================
// PROCESSES — нодовый движок бизнес-процессов (Фаза 1, B2B)
// Документ-канвас (nodes/edges/form) живёт в ProcessVersion.document;
// исполнение — token-движок строками БД (instance + step runs).
// Кросс-агрегатные ссылки (user/workspace) — плоскими id, как в RelationTuple.
// ============================================================

model ProcessDefinition {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  name        String
  description String?
  // 'team' — по командным правилам (manager+ редактирует, команда видит/запускает);
  // 'admins' — виден и запускается только admin+ («процессы для разработчиков»).
  visibility  String  @default("team")
  status      String  @default("active") // active | archived
  currentVersionId String? @map("current_version_id") // активная (опубликованная) версия
  createdById String  @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions  ProcessVersion[]
  instances ProcessInstance[]
  triggers  ProcessTrigger[]

  @@index([workspaceId, status])
  @@map("process_definitions")
}

model ProcessVersion {
  id           String    @id @default(uuid())
  definitionId String    @map("definition_id")
  version      Int
  status       String    @default("draft") // draft | published | superseded
  document     Json      // канвас-документ (nodes/edges/form) — источник правды, канвас лишь его рисует
  compiled     Json?     // скомпилированный план исполнения (заполняется при публикации)
  createdById  String    @map("created_by_id")
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  definition ProcessDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  instances  ProcessInstance[]

  @@unique([definitionId, version])
  @@index([definitionId, status])
  @@map("process_versions")
}

model ProcessInstance {
  id           String    @id @default(uuid())
  definitionId String    @map("definition_id")
  versionId    String    @map("version_id") // pin: запущенный процесс доживает на своей версии (модель Salesforce Flow)
  workspaceId  String    @map("workspace_id")
  status       String    @default("running") // running | done | cancelled | error
  variables    Json      @default("{}") // анкета процесса (значения стартовой формы)
  error        String?
  // Монотонный счётчик всех порождённых шагов (стоп-кран от бесконечных циклов).
  // Инкрементится в транзакции спавна → O(1) на переход вместо COUNT(*) (P8/A5).
  stepsSpawned Int       @default(1) @map("steps_spawned")
  startedById  String    @map("started_by_id") // «от имени кого» бежит процесс (для триггеров — runAs)
  triggerType  String    @default("manual") @map("trigger_type") // manual | event | schedule | webhook
  wakeAt       DateTime? @map("wake_at") // будильник крона (таймеры/SLA — Фаза 2)
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")

  definition ProcessDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  version    ProcessVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  steps      ProcessStepRun[]

  @@index([workspaceId, status])
  @@index([definitionId, status])
  @@index([startedById])
  @@index([wakeAt])
  @@map("process_instances")
}

model ProcessStepRun {
  id         String @id @default(uuid())
  instanceId String @map("instance_id")
  nodeId     String @map("node_id")   // id ноды в документе версии
  nodeType   String @map("node_type") // снимок типа ноды (списки без джойна версии)
  label      String? // снимок подписи ноды (P7): журнал/детали не парсят документ версии
  status     String @default("active") // active | done | error | cancelled

  // Активирован = side-effect шага (создание задачи/уведомление/таймер) уже отработал.
  // kick перезапускает только НЕ активированные ожидания (auto-ноды по флагу auto).
  activated Boolean @default(false)

  // Аренда шага (P3): взявший kick ставит leasedUntil перед внешним I/O (HTTP/LLM) и
  // отпускает per-instance лок на время вызова. Параллельный kick/крон пропускает
  // залоченный шаг (leasedUntil > now) — дорогая нода не задваивается, даже если
  // TTL инстанс-лока истёк под долгим агентом. По истечении аренды крон переберёт.
  leasedUntil DateTime? @map("leased_until")

  // Аудит/«секундомер отделов»: каждый шаг сам считает своё время.
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  outcome String? // выходной порт, по которому ушёл токен ('main' / 'true' / 'false')
  output  Json?
  error   String?

  taskId       String? @unique @map("task_id") // человеческий шаг → реальная задача Задачника
  assigneeId   String? @map("assignee_id")
  sourceStepId String? @map("source_step_id") // какой шаг породил этот (аудит токен-движка)

  // Ф2.5 — параллель: сколько токенов уже пришло в join-ноду (ждёт joinExpected).
  joinArrivals Int @default(0) @map("join_arrivals")

  // Ф2 — человеческие процессы:
  departmentId String?   @map("department_id") // задача на отдел (очередь): кто может claim
  claimedById  String?   @map("claimed_by_id") // кто забрал задачу отдела из очереди
  claimedAt    DateTime? @map("claimed_at")
  decision     String?   // одобрение: approved | rejected (снимок решения)
  deadlineAt   DateTime? @map("deadline_at")  // SLA человеческого шага ИЛИ время побудки паузы
  escalatedAt  DateTime? @map("escalated_at") // когда отправлена эскалация просрочки (дедуп)

  instance ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, status])
  @@index([assigneeId])
  // Кроны сканируют активные шаги (добивка + сверка задач) — без status-ведущего
  // индекса это seq-scan вечно растущей таблицы.
  @@index([status, startedAt])
  // Таймеры паузы + эскалация SLA сканируют дедлайны.
  @@index([deadlineAt])
  // «Входящие отдела»: claimable-шаги по отделу.
  @@index([departmentId])
  @@map("process_step_runs")
}

// ============================================================
// PROCESSES Ф3 — триггеры запуска + сейф кредов
// ============================================================

model ProcessTrigger {
  id           String  @id @default(uuid())
  definitionId String  @map("definition_id")
  workspaceId  String  @map("workspace_id")
  type         String  // event | schedule | webhook
  enabled      Boolean @default(true)
  // Тип события для event-триггера (P4): денормализован из config в колонку → роутер
  // фильтрует индексом, а не JSONB-path-запросом. Заполняется при публикации.
  eventType    String? @map("event_type")
  // event: {nodeId, eventType}; schedule: {nodeId, everyValue, everyUnit}; webhook/telegram: {nodeId, credentialId?}
  config       Json    @default("{}")
  webhookToken String? @unique @map("webhook_token") // секрет публичного эндпоинта
  runAsUserId  String  @map("run_as_user_id") // процесс запускается «от имени» этого сотрудника
  nextRunAt    DateTime? @map("next_run_at") // schedule: следующий запуск
  lastRunAt    DateTime? @map("last_run_at")
  createdById  String  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  definition ProcessDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([workspaceId, type, enabled])
  @@index([type, enabled, nextRunAt]) // schedule-крон
  @@index([workspaceId, type, enabled, eventType]) // P4: роутер событий по индексу
  @@index([definitionId])
  @@map("process_triggers")
}

model ProcessCredential {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  type        String   // header | basic | bearer
  // Шифр AES-256-GCM: base64(iv).base64(tag).base64(ciphertext) — секрет наружу не отдаётся.
  data        String
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@map("process_credentials")
}

// ============================================================
// ФИНАНСЫ (B2C) — managerial accounting book
// ============================================================
// An EDITABLE bookkeeping book with a double-entry STRUCTURE (Firefly III / QuickBooks
// model) — records about the OUTSIDE world (cash, bank card). Kept strictly separate
// from the wallet's immutable settlement ledger (coins): the wallet never gains rows
// here, Финансы shows coins as a read-only projection. Edits are allowed (soft delete)
// and every change lands in FinAuditLog — the bookkeeping answer to immutability.

// One book per owner (user today; workspace = the B2B path, created lazily by the
// Processes "record operation" node / future B2B UI). Ownership never moves (PRD).
model FinBook {
  id        String   @id @default(uuid())
  ownerType String   @default("user") @map("owner_type") // 'user' | 'workspace'
  ownerId   String   @map("owner_id")
  name      String   @default("Мои финансы")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts       FinAccount[]
  transactions   FinTransaction[]
  budgets        FinBudget[]
  people         FinPerson[]
  recurringRules FinRecurringRule[]

  @@unique([ownerType, ownerId]) // one book per owner
  @@map("fin_books")
}

// "Everything is an account" (Firefly III): asset (Наличные/Карта) and liability (долги)
// are the money sides; expense/income accounts ARE the categories (2-level tree via
// parentId); equity is the hidden opening-balance peg. Category rows ignore currencyCode
// (the transaction carries the money-side currency). Liability rows carry the debt
// passport (total / monthly / months / due day) — the remaining debt is the account's
// balance, never a mutable counter.
model FinAccount {
  id           String  @id @default(uuid())
  bookId       String  @map("book_id")
  kind         String // asset | liability | expense | income | equity
  subtype      String? // asset: cash|card|savings|other; liability: installment|loan
  parentId     String? @map("parent_id") // category tree (expense/income only)
  name         String
  icon         String?
  currencyCode String  @default("KZT") @map("currency_code")
  archived     Boolean @default(false)
  isSystem     Boolean @default(false) @map("is_system") // seeded equity account
  sortOrder    Int     @default(0) @map("sort_order")

  // Debt passport (kind = liability): рассрочка (installment) / кредит деньгами (loan).
  debtTotal      BigInt?   @map("debt_total") // full obligation in minor units
  debtMonthly    BigInt?   @map("debt_monthly") // monthly payment
  debtMonths     Int?      @map("debt_months")
  debtDueDay     Int?      @map("debt_due_day") // day of month the payment is due
  debtClosedAt   DateTime? @map("debt_closed_at")
  debtRemindedAt DateTime? @map("debt_reminded_at") // dedup: one payment_due reminder per day

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book     FinBook      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent   FinAccount?  @relation("FinCategoryTree", fields: [parentId], references: [id])
  children FinAccount[] @relation("FinCategoryTree")
  txFrom   FinTransaction[] @relation("FinTxFrom")
  txTo     FinTransaction[] @relation("FinTxTo")

  @@index([bookId, kind])
  @@index([parentId])
  @@map("fin_accounts")
}

// One movement of value from one account to another (the double-entry pair). The type
// (расход/доход/перевод/платёж по долгу…) is DERIVED from the from→to kinds, never stored.
// amount is denominated in the money-side currency (from for expenses/transfers, to for
// income); amountTo is set only for cross-currency money→money moves (обмен: two sums, no
// FX rates). Rows are soft-deleted (deletedAt) and every create/update/delete is audited.
model FinTransaction {
  id              String    @id @default(uuid())
  bookId          String    @map("book_id")
  fromAccountId   String    @map("from_account_id")
  toAccountId     String    @map("to_account_id")
  amount          BigInt // positive integer minor units (money-side currency)
  amountTo        BigInt?   @map("amount_to") // cross-currency: amount in the to-account currency
  currencyCode    String    @map("currency_code") // denormalized money-side currency
  occurredOn      DateTime  @map("occurred_on") @db.Date // date-only bookkeeping
  note            String?
  personUserId    String?   @map("person_user_id") // «на кого / от кого» — private analytics link
  personName      String?   @map("person_name") // snapshot (history survives Circle changes)
  createdById     String    @map("created_by_id")
  source          String    @default("manual") // manual | recurring | process | service | import
  recurringRuleId String?   @map("recurring_rule_id")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  book        FinBook    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromAccount FinAccount @relation("FinTxFrom", fields: [fromAccountId], references: [id])
  toAccount   FinAccount @relation("FinTxTo", fields: [toAccountId], references: [id])

  @@index([bookId, occurredOn])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([bookId, personUserId])
  @@map("fin_transactions")
}

// План-факт: a monthly limit for one category (or subcategory) in one currency.
// A parent-category limit counts its children's spending too (report-side aggregation).
model FinBudget {
  id                String   @id @default(uuid())
  bookId            String   @map("book_id")
  categoryAccountId String   @map("category_account_id")
  period            String // 'YYYY-MM'
  amount            BigInt // minor units
  currencyCode      String   @default("KZT") @map("currency_code")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  book FinBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, categoryAccountId, period])
  @@map("fin_budgets")
}

// «Близкие» — the curated quick-pick list for the «на кого» field (owner builds it from
// Circle). A name snapshot keeps history readable if the contact link is later severed.
model FinPerson {
  id        String   @id @default(uuid())
  bookId    String   @map("book_id")
  userId    String   @map("user_id")
  name      String // snapshot
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  book FinBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@map("fin_people")
}

// Повторяющиеся операции: a transaction template fired by FinanceCron. autoRecord=true
// writes the row silently (fixed sums: подписки/аренда); autoRecord=false sends a
// reminder with a one-tap confirm (плавающие суммы + платежи по долгам).
model FinRecurringRule {
  id            String    @id @default(uuid())
  bookId        String    @map("book_id")
  title         String
  fromAccountId String    @map("from_account_id")
  toAccountId   String    @map("to_account_id")
  amount        BigInt
  amountTo      BigInt?   @map("amount_to")
  note          String?
  personUserId  String?   @map("person_user_id")
  personName    String?   @map("person_name")
  interval      String // monthly | weekly
  dayOfMonth    Int?      @map("day_of_month") // monthly: 1..31 (clamped to month end)
  weekday       Int? // weekly: 1..7 (ISO)
  autoRecord    Boolean   @default(true) @map("auto_record")
  active        Boolean   @default(true)
  nextRunAt     DateTime  @map("next_run_at")
  lastRunAt     DateTime? @map("last_run_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  book FinBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([active, nextRunAt]) // cron sweep
  @@index([bookId])
  @@map("fin_recurring_rules")
}

// The bookkeeping audit trail: who created/updated/deleted what (before/after snapshots,
// BigInt → number). FK-free on purpose (like ledger_transfers) — audit rows outlive edits.
model FinAuditLog {
  id         String   @id @default(uuid())
  bookId     String   @map("book_id")
  entityType String   @map("entity_type") // transaction | account | budget | recurring | debt
  entityId   String   @map("entity_id")
  userId     String   @map("user_id")
  action     String // create | update | delete
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([bookId, createdAt])
  @@index([entityType, entityId])
  @@map("fin_audit_logs")
}

// ============================================
// FILES ENGINE (core/files) — платформенное хранилище файлов
// Метаданные здесь; байты — у драйвера (local disk | S3-совместимое хранилище).
// Доступ: владелец/загрузивший/public + наследование от привязанной сущности
// через FilesRefRegistry (без tuple-проекции — родитель = источник истины).
// ============================================

model FileObject {
  id            String    @id @default(uuid())
  ownerType     String    @map("owner_type") // user | workspace
  ownerId       String    @map("owner_id")
  uploaderId    String    @map("uploader_id")
  profile       String    @default("generic") // ключ FILE_PROFILES (shared)
  kind          String // image | video | audio | document | other
  name          String // оригинальное имя — только метаданные, в storageKey не попадает
  mime          String
  size          BigInt
  sha256        String?
  status        String    @default("uploading") // uploading | ready | failed | deleted
  visibility    String    @default("private") // private | public
  publicToken   String?   @unique @map("public_token") // неугадываемый токен вечной публичной ссылки
  scanStatus    String    @default("none") @map("scan_status") // none | pending | clean | infected
  storageDriver String    @map("storage_driver") // local | s3
  storageKey    String    @map("storage_key")
  uploadId      String?   @map("upload_id") // S3 multipart upload id (живёт пока uploading)
  meta          Json? // width/height/durationMs/pipeline/retries...
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  readyAt       DateTime? @map("ready_at")
  deletedAt     DateTime? @map("deleted_at")

  links    FileLink[]
  variants FileVariant[]

  @@index([ownerType, ownerId, status])
  @@index([status, createdAt]) // крон-свипы: зависшие uploading / просроченные deleted
  @@index([uploaderId])
  @@map("file_objects")
}

model FileLink {
  id          String   @id @default(uuid())
  fileId      String   @map("file_id")
  refType     String   @map("ref_type") // chat_message | task | listing | ... (резолвер в FilesRefRegistry)
  refId       String   @map("ref_id")
  role        String   @default("attachment") // attachment | avatar | gallery | ...
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, refType, refId, role])
  @@index([refType, refId])
  @@map("file_links")
}

model FileVariant {
  id         String   @id @default(uuid())
  fileId     String   @map("file_id")
  kind       String // thumb | medium | poster | waveform | text
  storageKey String   @map("storage_key")
  mime       String
  size       BigInt
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, kind])
  @@map("file_variants")
}

// Счётчик занятого места на владельца: инкременты в одной транзакции с
// complete/softDelete, ночная сверка кроном (пересчёт от file_objects).
model FileQuotaUsage {
  id         String   @id @default(uuid())
  ownerType  String   @map("owner_type") // user | workspace
  ownerId    String   @map("owner_id")
  bytesUsed  BigInt   @default(0) @map("bytes_used")
  filesCount Int      @default(0) @map("files_count")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([ownerType, ownerId])
  @@map("file_quota_usage")
}
