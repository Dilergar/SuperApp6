{
  "expo": {
    "name": "SuperApp6",
    "slug": "superapp6",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "superapp6",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.superapp6.app",
      "infoPlist": {
        "NSContactsUsageDescription": "SuperApp6 нужен доступ к контактам для добавления людей в ваше окружение"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.superapp6.app",
      "permissions": ["android.permission.READ_CONTACTS"]
    },
    "plugins": [
      "expo-router",
      "expo-contacts",
      "expo-secure-store"
    ]
  }
}
